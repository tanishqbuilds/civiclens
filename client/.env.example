# ─── Client Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env to git.

# Mapbox GL JS public token
# Get yours free at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Backend API base URL (without /api suffix)
VITE_API_BASE=https://d3coujrx9zr1yv.cloudfront.net
